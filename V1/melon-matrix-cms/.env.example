# ===== Server =====
PORT=3000
NODE_ENV=development
# Public URL of the site (no trailing slash) — used for canonical URLs, OG tags, sitemap
SITE_URL=http://localhost:3000

# ===== Session =====
SESSION_SECRET=change-this-to-a-long-random-string

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=melon_matrix

# ===== Initial admin user (used by `npm run setup`) =====
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@melonmatrix.com
ADMIN_PASSWORD=ChangeMe123!
