<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<div class="adm-shell">
  <%- include('partials/sidebar') %>
  <main class="adm-main">
    <div class="adm-head">
      <div><h1>Tags</h1><p class="sub">Fine-grained labels for posts</p></div>
    </div>

    <%- include('partials/flash') %>

    <div class="panel">
      <h3>Add tags</h3>
      <form method="post" action="/admin/tags" style="display:flex; gap:10px; flex-wrap:wrap;">
        <div class="field" style="margin:0; flex:1; min-width:220px;">
          <input type="text" name="name" placeholder="One or more tags, comma-separated" required />
        </div>
        <button type="submit" class="btn btn-red">Add</button>
      </form>
    </div>

    <div class="table-wrap">
      <table>
        <thead><tr><th>Name</th><th>Slug</th><th>Posts</th><th></th></tr></thead>
        <tbody>
          <% if (!tags.length) { %><tr><td colspan="4" class="empty-note">No tags yet.</td></tr><% } %>
          <% tags.forEach((t) => { %>
          <tr>
            <td><span class="row-title"><%= t.name %></span></td>
            <td><%= t.slug %></td>
            <td><%= t.post_count %></td>
            <td>
              <div class="row-actions">
                <form method="post" action="/admin/tags/<%= t.id %>/delete" onsubmit="return confirm('Delete this tag?');">
                  <button type="submit" class="btn btn-danger-ghost btn-sm">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</div>
</body>
</html>
