  <!-- ===================== THE MATRIX GROWTH ENGINE ===================== -->
  <section class="section engine">
    <div class="container">
      <h2 class="h2 center"><%- content.engine_title || 'The Matrix <em>growth</em> engine' %></h2>
      <p class="lead center"><%- content.engine_lead || '' %></p>

      <div class="engine-grid">
        <div class="engine-steps" id="engineSteps">
          <div class="step active">
            <span class="step-num">01</span>
            <button class="step-body" type="button">
              <h4>Discover</h4>
              <div class="step-desc"><p>Strategy, creative and optimization -built to grow your brand.</p></div>
            </button>
          </div>
          <div class="step">
            <span class="step-num">02</span>
            <button class="step-body" type="button">
              <h4>Create</h4>
              <div class="step-desc"><p>We design and build conversion-focused experiences that bring your strategy to life.</p></div>
            </button>
          </div>
          <div class="step">
            <span class="step-num">03</span>
            <button class="step-body" type="button">
              <h4>Scale</h4>
              <div class="step-desc"><p>We optimize, test, and grow what works—turning momentum into sustainable growth.</p></div>
            </button>
          </div>
        </div>

