          <li data-cat="shopify"><span class="dot"></span> Shopify</li>
          <li data-cat="web-development"><span class="dot"></span> Web Development</li>
        </ul>
      </div>

      <div class="plans-wrap">
        <!-- Digital Marketing -->
        <div class="plan-set active" data-cat="digital-marketing">
