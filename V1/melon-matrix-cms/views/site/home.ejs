  <!-- ===================== DRIVING / SERVICES ===================== -->
  <section class="section driving" id="services">
    <div class="container driving-grid">
      <div class="driving-left">
        <p class="eyebrow eyebrow-green"><%- content.driving_eyebrow || 'B2B GROWTH. ENGINEERED.' %></p>
        <h2 class="h2"><%- content.driving_title || 'Driving a Better Way of Doing Marketing to Help You <em>Succeed.</em>' %></h2>
        <p class="lead"><%- content.driving_lead || '' %></p>
        <a href="#cta" class="btn btn-green btn-arrow"><%= content.driving_btn || 'Book A Quick Call' %> <span class="arrow-circle">→</span></a>

        <div class="stats">
          <div class="stat">
            <span class="stat-num"><%= content.stat1_num || '45%' %></span>
            <span class="stat-label"><%= content.stat1_label || 'MORE PIPELINE' %></span>
            <span class="stat-desc"><%= content.stat1_desc || '' %></span>
          </div>
          <div class="stat">
            <span class="stat-num"><%= content.stat2_num || '75%' %></span>
            <span class="stat-label"><%= content.stat2_label || 'LOWER IN-HOUSE EXECUTION COST' %></span>
            <span class="stat-desc"><%= content.stat2_desc || '' %></span>
          </div>
          <div class="stat">
            <span class="stat-num"><%= content.stat3_num || '50+' %></span>
            <span class="stat-label"><%= content.stat3_label || 'B2B CLIENTS' %></span>
            <span class="stat-desc"><%= content.stat3_desc || '' %></span>
          </div>
        </div>
      </div>

      <div class="driving-right">
        <h3 class="services-title"><%= content.services_title || 'Our services' %></h3>
        <div class="services-grid">
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-monitor"/></svg></span><span class="svc-name">Web Design &amp; Development</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-bag"/></svg></span><span class="svc-name">Shopify (Everything)</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-trending"/></svg></span><span class="svc-name">Performance Marketing</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-settings"/></svg></span><span class="svc-name">Marketing Automation</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-search"/></svg></span><span class="svc-name">SEO &amp; Organic Growth</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-edit"/></svg></span><span class="svc-name">Content Marketing</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-share"/></svg></span><span class="svc-name">Social Media Growth</span><span class="svc-arrow">→</span></a>
          <a class="svc-card" href="/contact"><span class="svc-ico"><svg class="ico"><use href="#i-pen"/></svg></span><span class="svc-name">Brand Design &amp; UI/UX</span><span class="svc-arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SHOPIFY STORIES THAT SCALE ===================== -->
  <section class="section stories">
    <div class="container stories-grid">
      <div class="stories-art">
        <img src="/assets/dashboard.png" alt="Shopify admin dashboard showing growing revenue" />
      </div>
      <div class="stories-copy">
        <p class="eyebrow eyebrow-green"><%- content.stories_eyebrow || 'SHOPIFY, GROWTH ENGINE.' %></p>
        <h2 class="h2"><%- content.stories_title || 'We build Shopify <br /><em>stories that scale.</em>' %></h2>
        <p class="lead"><%- content.stories_lead || '' %></p>
        <a href="#cta" class="btn btn-red"><%= content.stories_btn || 'Book a Free Audit' %></a>
        <div class="mini-features">
          <div class="mini-feat"><span class="mini-ico"><svg class="ico"><use href="#i-trending"/></svg></span><span>Conversion<br />Focused</span></div>
          <div class="mini-feat"><span class="mini-ico"><svg class="ico"><use href="#i-zap"/></svg></span><span>Built for<br />Speed</span></div>
          <div class="mini-feat"><span class="mini-ico"><svg class="ico"><use href="#i-shield"/></svg></span><span>Scalable<br />Growth</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SHOPIFY SYSTEMS BUILT FOR GROWTH ===================== -->
  <section class="section systems" id="systems">
    <div class="container">
      <div class="systems-head">
        <div>
          <h2 class="h2"><%- content.systems_title || 'Shopify Systems <br />Built for <em>Growth</em>' %></h2>
          <p class="lead"><%- content.systems_lead || '' %></p>
        </div>
        <div class="systems-cards">
          <span class="sc-badge"><img src="/assets/shopify.png" alt="Shopify" /></span>
          <div class="sc-main">
            <span class="sc-label">Total revenue</span>
            <div class="sc-rev"><strong>$248,420</strong><span class="sc-up">↑ 28%</span></div>
            <div class="sc-plot">
              <div class="sc-yaxis"><span>$300k</span><span>$150k</span><span>$0</span></div>
              <svg class="sc-graph" viewBox="0 0 320 150" preserveAspectRatio="none" aria-hidden="true">
                <defs>
                  <linearGradient id="revFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#22c55e" stop-opacity=".22" />
                    <stop offset="1" stop-color="#22c55e" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <path fill="url(#revFill)" d="M0,120 L25,112 L48,118 L72,96 L95,103 L120,82 L145,90 L168,70 L190,60 L215,73 L240,46 L262,56 L286,32 L310,14 L320,14 L320,150 L0,150 Z" />
                <path fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M0,120 L25,112 L48,118 L72,96 L95,103 L120,82 L145,90 L168,70 L190,60 L215,73 L240,46 L262,56 L286,32 L310,14" />
                <circle cx="310" cy="14" r="6" fill="#16a34a" />
              </svg>
            </div>
            <div class="sc-xaxis"><span>Apr 1</span><span>Apr 15</span></div>
          </div>
          <div class="sc-small">
            <strong>3.64%</strong><span class="sc-up">↑ 18%</span>
          </div>
          <div class="sc-mini">
            <svg viewBox="0 0 140 60" preserveAspectRatio="none" aria-hidden="true">
              <path fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M4,48 L24,44 L40,50 L58,34 L74,40 L92,22 L110,30 L128,10 L136,6" />
            </svg>
          </div>
        </div>
      </div>

      <div class="cards-4">
        <div class="growth-card">
          <span class="gc-ico"><svg class="ico"><use href="#i-cart"/></svg></span>
          <span class="gc-num">01</span>
          <h3>Conversion-First Storefronts</h3>
          <p>Custom Shopify and Shopify Plus stores designed for speed, clarity, mobile shopping, and higher conversion.</p>
          <a href="/contact" class="gc-link">Explore Storefronts →</a>
        </div>
        <div class="growth-card">
          <span class="gc-ico"><svg class="ico"><use href="#i-grid"/></svg></span>
          <span class="gc-num">02</span>
          <h3>Custom Shopify Apps</h3>
          <p>Custom Shopify and Shopify Plus mobile shopping, and higher conversion.</p>
          <a href="/contact" class="gc-link">Explore Storefronts →</a>
        </div>
        <div class="growth-card">
          <span class="gc-ico"><svg class="ico"><use href="#i-cloud"/></svg></span>
          <span class="gc-num">03</span>
          <h3>Seamless Migration</h3>
          <p>Custom Shopify and Shopify Plus stores designed for speed, clarity, mobile shopping, and higher conversion.</p>
          <a href="/contact" class="gc-link">Explore Storefronts →</a>
        </div>
        <div class="growth-card">
          <span class="gc-ico"><svg class="ico"><use href="#i-bar"/></svg></span>
          <span class="gc-num">04</span>
          <h3>Growth &amp; Optimization</h3>
          <p>Ongoing CRO, speed tuning, and ROI-driven marketing that compounds after launch.</p>
          <a href="/contact" class="gc-link">Explore Storefronts →</a>
        </div>
      </div>
    </div>
