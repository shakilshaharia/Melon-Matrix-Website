<%
  function fmtDate(d) {
    if (!d) return "";
    return new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
  }
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>

  <%- include('../partials/icons') %>
  <%- include('../partials/navbar') %>

  <!-- ===================== POST HERO ===================== -->
  <section class="page-hero post-hero">
    <span class="contact-blob cb-1" aria-hidden="true"></span>
    <span class="contact-blob cb-2" aria-hidden="true"></span>
    <div class="container">
      <% if (post.category_name) { %>
        <a href="/blog/category/<%= post.category_slug %>" class="post-hero-tag"><%= post.category_name %></a>
      <% } %>
      <h1 class="hero-title post-hero-title"><%= post.title %></h1>
      <div class="post-hero-meta">
        <span><%= fmtDate(post.published_at) %></span>
        <span class="dot-sep">•</span>
        <span class="post-read"><svg class="ico"><use href="#i-clock"/></svg> <%= post.read_time || '5 min' %> read</span>
      </div>
    </div>
  </section>

  <!-- ===================== POST BODY ===================== -->
  <section class="section post-main">
    <div class="container post-layout">

      <article class="post-article">
        <% if (post.featured_image) { %>
        <figure class="post-figure">
          <img src="<%= post.featured_image %>" alt="<%= post.title %>" />
        </figure>
        <% } %>

        <div class="post-content">
          <%- post.content %>
        </div>

        <% if (tags.length) { %>
        <div class="post-tags">
          <% tags.forEach((t) => { %><span class="post-tag-pill">#<%= t.name %></span><% }) %>
        </div>
        <% } %>
      </article>

      <aside class="post-sidebar">
        <div class="sidebar-widget">
          <h4>Search</h4>
          <form class="blog-search" action="/blog" method="get" role="search">
            <input type="search" name="q" placeholder="Search articles…" aria-label="Search articles" />
            <button type="submit" aria-label="Search"><svg class="ico"><use href="#i-search"/></svg></button>
          </form>
        </div>

        <% if (recent.length) { %>
        <div class="sidebar-widget">
          <h4>Recent Posts</h4>
          <ul class="recent-list">
            <% recent.forEach((r) => { %>
            <li>
              <a href="/blog/<%= r.slug %>">
                <img src="<%= r.featured_image || '/assets/dashboard.png' %>" alt="" loading="lazy" />
                <span>
                  <strong><%= r.title %></strong>
                  <small><%= fmtDate(r.published_at) %></small>
                </span>
              </a>
            </li>
            <% }) %>
          </ul>
        </div>
        <% } %>

        <div class="sidebar-widget">
          <h4>Categories</h4>
          <ul class="cat-list">
            <% categories.filter(c => c.post_count > 0).forEach((c) => { %>
            <li><a href="/blog/category/<%= c.slug %>"><%= c.name %> <span><%= c.post_count %></span></a></li>
            <% }) %>
          </ul>
        </div>

        <div class="sidebar-widget sidebar-cta">
          <h4>Need results like these?</h4>
          <p>Book a free audit and find out what's holding your growth back.</p>
          <a href="/contact" class="btn btn-red">Book a Free Audit</a>
        </div>
      </aside>

    </div>

    <% if (related.length) { %>
    <div class="container related-wrap">
      <h2 class="h2">Related <em>articles</em></h2>
      <div class="blog-grid related-grid">
        <% related.forEach((p) => { %>
        <article class="blog-card">
          <a href="/blog/<%= p.slug %>" class="bc-media">
            <img src="<%= p.featured_image || '/assets/dashboard.png' %>" alt="<%= p.title %>" loading="lazy" />
            <% if (p.category_name) { %><span class="post-tag"><%= p.category_name %></span><% } %>
          </a>
          <div class="bc-body">
            <div class="post-meta">
              <span><%= fmtDate(p.published_at) %></span>
              <span class="dot-sep">•</span>
              <span class="post-read"><svg class="ico"><use href="#i-clock"/></svg> <%= p.read_time || '5 min' %></span>
            </div>
            <h3><a href="/blog/<%= p.slug %>"><%= p.title %></a></h3>
            <p><%= p.excerpt %></p>
            <a href="/blog/<%= p.slug %>" class="bc-link">Read more <svg class="ico"><use href="#i-arrow"/></svg></a>
          </div>
        </article>
        <% }) %>
      </div>
    </div>
    <% } %>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="section cta-wrap">
    <div class="container">
      <div class="cta-box">
        <div class="cta-blob cta-blob-1"></div>
        <div class="cta-blob cta-blob-2"></div>
        <div class="cta-content">
          <h2 class="cta-title">Get a free call</h2>
          <p>Personalize your plan for custom solutions according to your business needs</p>
          <a href="/contact" class="btn btn-green btn-lg">Book an Assessment</a>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/footer') %>
</body>
</html>
